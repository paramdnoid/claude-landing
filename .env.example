# Endpoint für das Kontaktformular (Formspree, Web3Forms, EmailJS …).
# Solange leer, läuft das Formular im Demo-Modus.
VITE_FORM_ENDPOINT=

# Kontakt-Adresse (mailto-Fallback in der Contact Section).
VITE_CONTACT_EMAIL=hello@zian-ai.dev

# Öffentliche Site-URL (für canonical / OG / sitemap).
VITE_SITE_URL=https://zian-ai.dev

# --- AI-Demo (Showcase) ---
# Wenn gesetzt: streamt aus deinem Ollama-Endpoint (OpenAI-kompatibler /api/chat).
# Wenn leer:    Mock mit Ollama-Branding (vordefinierte Antworten).
VITE_OLLAMA_ENDPOINT=
VITE_OLLAMA_MODEL=llama3.2:3b

# --- Analytics (privacy-friendly, cookie-aware) ---
# Snippet-URL (z.B. https://plausible.io/js/script.js oder Umami-URL).
# Wenn leer: kein Banner, kein Tracking.
VITE_ANALYTICS_SCRIPT_URL=
VITE_ANALYTICS_SITE_ID=
VITE_ANALYTICS_DOMAIN=zian-ai.dev

# --- Social profile URLs (rendered in the Connect section) ---
# Each link is hidden when the corresponding variable is empty, so
# the production build can't ship placeholder handles by accident.
VITE_SOCIAL_GITHUB=
VITE_SOCIAL_TWITTER=
VITE_SOCIAL_LINKEDIN=
