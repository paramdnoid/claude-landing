{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_QUALITY_GATE": "1",
    "CLAUDE_CODE_DISABLE_1M_CONTEXT": "1",
    "CLAUDE_QUALITY_GATE_MAX_SECONDS": "300",
    "CLAUDE_AGENT_TEAM_PROFILE": "senior-vite-react-tailwind-ts-i18n-three-gsap"
  },
  "teammateMode": "in-process",
  "permissions": {
    "defaultMode": "plan",
    "disableBypassPermissionsMode": "disable",
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Agent",
      "WebSearch",
      "WebFetch(domain:react.dev)",
      "WebFetch(domain:nextjs.org)",
      "WebFetch(domain:tailwindcss.com)",
      "WebFetch(domain:typescriptlang.org)",
      "WebFetch(domain:i18next.com)",
      "WebFetch(domain:react.i18next.com)",
      "WebFetch(domain:threejs.org)",
      "WebFetch(domain:gsap.com)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(node --version)",
      "Bash(npm --version)",
      "Bash(pnpm --version)",
      "Bash(yarn --version)",
      "Bash(bun --version)",
      "Bash(npm run typecheck)",
      "Bash(npm run typecheck -- *)",
      "Bash(npm run lint)",
      "Bash(npm run lint -- *)",
      "Bash(npm run test)",
      "Bash(npm run test -- *)",
      "Bash(npm run test:coverage)",
      "Bash(npm run build)",
      "Bash(npm run test:e2e)",
      "Bash(npm run test:e2e -- *)",
      "WebFetch(domain:www.typescriptlang.org)",
      "WebFetch(domain:www.i18next.com)",
      "WebFetch(domain:github.com)"
    ],
    "ask": [
      "Bash(npm install *)",
      "Bash(npm i *)",
      "Bash(npm uninstall *)",
      "Bash(pnpm add *)",
      "Bash(pnpm remove *)",
      "Bash(yarn add *)",
      "Bash(yarn remove *)",
      "Bash(bun add *)",
      "Bash(bun remove *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git pull *)",
      "Bash(gh pr *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.local)",
      "Read(./.env.*.local)",
      "Read(./.env.development)",
      "Read(./.env.production)",
      "Read(./.env.test)",
      "Read(./.env.staging)",
      "Read(./.env.prod)",
      "Read(./.env.preview)",
      "Read(./.env.backup)",
      "Read(./.env.bak)",
      "Read(./.env.*.backup)",
      "Read(./.env.*.bak)",
      "Read(./secrets/**)",
      "Read(./**/secrets/**)",
      "Read(./config/credentials.json)",
      "Edit(./.env)",
      "Edit(./.env.local)",
      "Edit(./.env.*.local)",
      "Edit(./.env.development)",
      "Edit(./.env.production)",
      "Edit(./.env.test)",
      "Edit(./.env.staging)",
      "Edit(./.env.prod)",
      "Edit(./.env.preview)",
      "Edit(./.env.backup)",
      "Edit(./.env.bak)",
      "Edit(./.env.*.backup)",
      "Edit(./.env.*.bak)",
      "Edit(./secrets/**)",
      "Edit(./**/secrets/**)",
      "Write(./.env)",
      "Write(./.env.local)",
      "Write(./.env.*.local)",
      "Write(./.env.development)",
      "Write(./.env.production)",
      "Write(./.env.test)",
      "Write(./.env.staging)",
      "Write(./.env.prod)",
      "Write(./.env.preview)",
      "Write(./.env.backup)",
      "Write(./.env.bak)",
      "Write(./.env.*.backup)",
      "Write(./.env.*.bak)",
      "Write(./secrets/**)",
      "Write(./**/secrets/**)",
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -fd*)",
      "Bash(chmod 777 *)",
      "Bash(chown *)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "failIfUnavailable": false,
    "autoAllowBashIfSandboxed": true,
    "excludedCommands": [
      "docker *"
    ],
    "filesystem": {
      "denyRead": [
        "~/.aws/credentials",
        "~/.ssh",
        "~/.config/gh/hosts.yml"
      ],
      "denyWrite": [
        "/etc",
        "/usr",
        "/bin",
        "/sbin",
        "/System"
      ]
    },
    "network": {
      "allowedDomains": [
        "react.dev",
        "nextjs.org",
        "tailwindcss.com",
        "typescriptlang.org",
        "i18next.com",
        "react.i18next.com",
        "threejs.org",
        "gsap.com",
        "registry.npmjs.org",
        "*.npmjs.org",
        "registry.yarnpkg.com",
        "github.com",
        "www.typescriptlang.org",
        "www.i18next.com"
      ]
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3",
            "args": [
              "${CLAUDE_PROJECT_DIR}/.claude/hooks/guard_dangerous_bash.py"
            ],
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Read|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3",
            "args": [
              "${CLAUDE_PROJECT_DIR}/.claude/hooks/guard_sensitive_files.py"
            ],
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3",
            "args": [
              "${CLAUDE_PROJECT_DIR}/.claude/hooks/mark_validation_needed.py"
            ],
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3",
            "args": [
              "${CLAUDE_PROJECT_DIR}/.claude/hooks/quality_gate_stop.py"
            ],
            "timeout": 360
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3",
            "args": [
              "${CLAUDE_PROJECT_DIR}/.claude/hooks/subagent_context.py"
            ],
            "timeout": 5
          }
        ]
      }
    ],
    "ConfigChange": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3",
            "args": [
              "${CLAUDE_PROJECT_DIR}/.claude/hooks/log_event.py"
            ],
            "timeout": 3
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3",
            "args": [
              "${CLAUDE_PROJECT_DIR}/.claude/hooks/log_event.py"
            ],
            "timeout": 2
          }
        ]
      }
    ]
  }
}
